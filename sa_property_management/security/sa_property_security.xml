<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Category -->
        <record id="module_category_sa_property" model="ir.module.category">
            <field name="name">Property Management</field>
            <field name="description">Manage real-estate properties, bookings,
                payment plans, dealerships and property transfers.</field>
            <field name="sequence">25</field>
        </record>

        <!-- Groups -->
        <record id="group_sa_property_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_sa_property"/>
            <field name="implied_ids"
                   eval="[(4, ref('base.group_user')),
                          (4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="comment">Property Management user: can view and operate on
                properties, bookings and receivables assigned to them.</field>
        </record>

        <record id="group_sa_property_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_sa_property"/>
            <field name="implied_ids"
                   eval="[(4, ref('group_sa_property_user')),
                          (4, ref('account.group_account_invoice'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Full access to property management: configuration,
                approvals, transfers, financial integration.</field>
        </record>

        <!-- Record Rules -->
        <record id="rule_sa_property_user_company" model="ir.rule">
            <field name="name">Property: multi-company</field>
            <field name="model_id" ref="model_sa_property"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_sa_property_user'))]"/>
        </record>

        <record id="rule_sa_booking_user_company" model="ir.rule">
            <field name="name">Booking: multi-company</field>
            <field name="model_id" ref="model_sa_property_booking"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_sa_property_user'))]"/>
        </record>

        <record id="rule_sa_transfer_user_company" model="ir.rule">
            <field name="name">Transfer: multi-company</field>
            <field name="model_id" ref="model_sa_property_transfer"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_sa_property_user'))]"/>
        </record>

    </data>
</odoo>
