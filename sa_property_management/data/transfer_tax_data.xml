<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Pakistan property transfer taxes — typical 2024 rates.
             Account is NOT pre-set: the user must wire each tax to an account
             via Property Management → Configuration → Transfer Taxes. -->

        <record id="tax_cvt" model="sa.transfer.tax">
            <field name="name">Capital Value Tax (CVT)</field>
            <field name="code">CVT</field>
            <field name="sequence">10</field>
            <field name="computation">percent_dc</field>
            <field name="rate">2.0</field>
            <field name="payer">buyer</field>
            <field name="property_type_filter">all</field>
        </record>

        <record id="tax_stamp_duty" model="sa.transfer.tax">
            <field name="name">Stamp Duty</field>
            <field name="code">STAMP</field>
            <field name="sequence">20</field>
            <field name="computation">percent_dc</field>
            <field name="rate">3.0</field>
            <field name="payer">buyer</field>
            <field name="property_type_filter">all</field>
        </record>

        <record id="tax_registration_fee" model="sa.transfer.tax">
            <field name="name">Registration Fee</field>
            <field name="code">REG</field>
            <field name="sequence">30</field>
            <field name="computation">percent_dc</field>
            <field name="rate">1.0</field>
            <field name="payer">buyer</field>
            <field name="property_type_filter">all</field>
        </record>

        <record id="tax_fbr_236k_filer" model="sa.transfer.tax">
            <field name="name">FBR Tax 236K (Filer - Buyer)</field>
            <field name="code">FBR236K</field>
            <field name="sequence">40</field>
            <field name="computation">percent_dc</field>
            <field name="rate">3.0</field>
            <field name="payer">buyer</field>
            <field name="property_type_filter">all</field>
        </record>

        <record id="tax_fbr_236c_filer" model="sa.transfer.tax">
            <field name="name">FBR Tax 236C (Filer - Seller)</field>
            <field name="code">FBR236C</field>
            <field name="sequence">50</field>
            <field name="computation">percent_dc</field>
            <field name="rate">3.0</field>
            <field name="payer">seller</field>
            <field name="property_type_filter">all</field>
        </record>

        <record id="tax_capital_gains" model="sa.transfer.tax">
            <field name="name">Capital Gains Tax (CGT)</field>
            <field name="code">CGT</field>
            <field name="sequence">60</field>
            <field name="computation">percent</field>
            <field name="rate">5.0</field>
            <field name="payer">seller</field>
            <field name="property_type_filter">all</field>
        </record>

    </data>
</odoo>
