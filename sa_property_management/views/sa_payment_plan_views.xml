<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sa_payment_plan_tree" model="ir.ui.view">
        <field name="name">sa.payment.plan.tree</field>
        <field name="model">sa.payment.plan</field>
        <field name="arch" type="xml">
            <list string="Payment Plans">
                <field name="name"/>
                <field name="code"/>
                <field name="down_payment_percent"/>
                <field name="installment_count"/>
                <field name="frequency"/>
                <field name="on_possession_percent"/>
                <field name="total_percent" widget="percentage"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_sa_payment_plan_form" model="ir.ui.view">
        <field name="name">sa.payment.plan.form</field>
        <field name="model">sa.payment.plan</field>
        <field name="arch" type="xml">
            <form string="Payment Plan">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. 3 Year Standard"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="active" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="down_payment_percent"/>
                            <field name="installment_count"/>
                            <field name="frequency"/>
                            <field name="on_possession_percent"/>
                            <field name="installment_percent_each" readonly="1"/>
                            <field name="total_percent" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Extra / Balloon Lines">
                            <field name="extra_line_ids">
                                <list editable="bottom">
                                    <field name="after_installment"/>
                                    <field name="name"/>
                                    <field name="percent"/>
                                </list>
                            </field>
                            <p class="text-muted">Tip: extras are charged together with the
                                referenced installment number (e.g. a 5% balloon at
                                month 12 in a monthly plan).</p>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sa_payment_plan" model="ir.actions.act_window">
        <field name="name">Payment Plans</field>
        <field name="res_model">sa.payment.plan</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
