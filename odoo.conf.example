[options]
addons_path = /usr/lib/python3/dist-packages/odoo/addons,/mnt/extra-addons
data_dir = /var/lib/odoo

; Master password for database management operations. CHANGE THIS.
admin_passwd = CHANGE_ME

; Database connection. Update to match your environment / docker-compose.
db_host = db
db_port = 5432
db_user = odoo
db_password = CHANGE_ME
db_name = sa_demo

list_db = True
without_demo = False
log_level = info
xmlrpc_port = 8069
longpolling_port = 8072
proxy_mode = True
